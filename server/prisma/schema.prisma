generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomRole {
  ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())

  rooms        RoomMember[]
  bookings     Booking[]      @relation("creator")
  participants BookingParticipant[]
}

model Room {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime     @default(now())

  members     RoomMember[]
  bookings    Booking[]
}

model RoomMember {
  id     Int      @id @default(autoincrement())
  user   User     @relation(fields: [userId], references: [id])
  userId Int
  room   Room     @relation(fields: [roomId], references: [id])
  roomId Int
  role   RoomRole @default(USER)

  @@unique([userId, roomId])
}

model Booking {
  id          Int       @id @default(autoincrement())
  room        Room      @relation(fields: [roomId], references: [id])
  roomId      Int
  title       String?
  description String?
  start       DateTime
  end         DateTime
  createdBy   User      @relation("creator", fields: [createdById], references: [id])
  createdById Int
  participants BookingParticipant[]
  createdAt   DateTime  @default(now())

  @@index([roomId, start, end])
}

model BookingParticipant {
  id        Int     @id @default(autoincrement())
  booking   Booking @relation(fields: [bookingId], references: [id])
  bookingId Int
  user      User    @relation(fields: [userId], references: [id])
  userId    Int

  @@unique([bookingId, userId])
}
